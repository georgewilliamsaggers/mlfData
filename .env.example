# Copy to .env for local dev. On Railway, set these in the service Variables tab.

# HTTP (Railway sets PORT automatically)
PORT=3000

# Partner PostgreSQL (read-only; views under partner_schema)
PGHOST=
PGPORT=5432
PGDATABASE=postgres
PGUSER=
PGPASSWORD=
# For managed/cloud hosts: try PGSSL=require or PGSSL=no-verify
# PGSSL=require
# PGCONNECT_TIMEOUT_MS=20000
# PGPOOL_MAX=10

# Supabase (service role — server/jobs only; never expose to clients)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: override default table name for usage analytics
# SUPABASE_USAGE_TABLE=usage

# Daily cron timezone (IANA). Default Africa/Harare (CAT).
CRON_TIMEZONE=Africa/Harare

# Optional: /api/chat natural-language SQL
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
