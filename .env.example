# =============================================================================
# Environment variables for mlf-partner-db
# =============================================================================
# Local: copy to .env and fill in values (cp .env.example .env)
#
# Railway: after connecting this repo, open your service → Variables.
# Railway scans the repo for .env.example and can suggest / bulk-import keys.
# Use "Raw Editor" to paste KEY=value lines, then replace empty values with secrets.
# Do NOT commit a real .env file with passwords.
# =============================================================================

# --- HTTP (Railway injects PORT automatically; you usually omit PORT) ---
PORT=

# --- Partner PostgreSQL (required for API + jobs) ---
PGHOST=
PGPORT=5432
PGDATABASE=postgres
PGUSER=
PGPASSWORD=
# Schema with integration_clients, integration_transactions, etc.
PGSCHEMA=mlf_schema
# Cloud / DigitalOcean pooler: try require first; use no-verify if TLS cert chain errors
PGSSL=no-verify
# PGCONNECT_TIMEOUT_MS=20000
# PGPOOL_MAX=10

# --- Supabase (required for daily/hourly jobs that write metrics) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Optional alias (same value as service role)
# SUPABASE_SERVICE_KEY=
# SUPABASE_STORAGE_BUCKET=snapshots
# SUPABASE_USAGE_TABLE=usage
# SUPABASE_ACTIVE_USERS_TABLE=usage

# --- Cron (IANA timezone for midnight + hourly schedules) ---
CRON_TIMEZONE=Africa/Harare

# --- Optional: POST /api/chat ---
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# --- Optional: ad-hoc SQL CLI (database/hobbiton/query.js) ---
# QUERY=
